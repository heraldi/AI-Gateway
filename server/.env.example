# AI Gateway Configuration

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database path (relative to server directory)
DB_PATH=./data/gateway.db

# Admin password for dashboard (change this!)
ADMIN_PASSWORD=changeme123

# Secret for signing gateway API keys
JWT_SECRET=change-this-to-a-random-secret-string

# CORS - comma-separated list of allowed origins (* for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info

# Max request body size
MAX_BODY_SIZE=10mb

# Request log retention (days, 0 = keep forever)
LOG_RETENTION_DAYS=30

# Chrome extension token (must match the token saved in extension Settings)
EXTENSION_TOKEN=ext-token-change-me

# OAuth provider app credentials
# Leave empty if you do not use that provider.
IFLOW_CLIENT_ID=
IFLOW_CLIENT_SECRET=
QWEN_CLIENT_ID=
GITHUB_OAUTH_CLIENT_ID=
KIMI_CODING_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
CODEX_OAUTH_CLIENT_ID=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
